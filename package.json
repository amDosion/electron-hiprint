{
  "name": "electron-hiprint",
  "version": "1.0.25",
  "description": "vue-plugin-hiprint client",
  "main": "main.js",
  "author": "CcSimple<840054486@qq.com>",
  "license": "MIT",
  "homepage": "https://github.com/amDosion/electron-hiprint#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amDosion/electron-hiprint.git"
  },
  "bugs": {
    "url": "https://github.com/amDosion/electron-hiprint/issues"
  },
  "scripts": {
    "start": "node ./build/write-build-info.js && node start.js",
    "postinstall": "npm run fix-sqlite3 && node ./build/write-build-info.js",
    "fix-sqlite3": "node ./build/fixSqlite3bug.js",
    "sync-plugin": "node ./tools/sync-builtin-plugin.js",
    "build-w": "node ./tools/build-package.js build-w",
    "build-w-64": "node ./tools/build-package.js build-w-64",
    "build-m": "node ./tools/build-package.js build-m",
    "build-m-arm64": "node ./tools/build-package.js build-m-arm64",
    "build-m-universal": "node ./tools/build-package.js build-m-universal",
    "build-l": "node ./tools/build-package.js build-l",
    "build-l-arm64": "node ./tools/build-package.js build-l-arm64",
    "build-kylin": "node ./tools/build-package.js build-kylin",
    "compress": "node ./tools/code_compress --compress",
    "restore": "node ./tools/code_compress --restore",
    "build-all": "node ./tools/build-package.js build-all",
    "releases": "npm run compress && npm run build-all && npm run restore"
  },
  "build": {
    "productName": "hiprint",
    "appId": "com.simple.cc.hiprint",
    "copyright": "CcSimple<840054486@qq.com>",
    "directories": {
      "output": "out"
    },
    "asar": true,
    "files": [
      "**/*",
      "!.git/**",
      "!.omx/**",
      "!docs/**",
      "!tools/repro/**",
      "!out/**"
    ],
    "extraResources": [
      "plugin/*"
    ],
    "electronDownload": {
      "mirror": "https://npmmirror.com/mirrors/electron/"
    },
    "nsis": {
      "oneClick": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "./build/icons/icon.ico",
      "uninstallerIcon": "./build/icons/icon.ico",
      "installerHeaderIcon": "./build/icons/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Hiprint",
      "include": "installer.nsh"
    },
    "mac": {
      "icon": "./build/icons/icon.icns",
      "artifactName": "${productName}-${version}.${ext}",
      "target": [
        "dmg"
      ],
      "identity": null
    },
    "dmg": {
      "sign": false
    },
    "win": {
      "icon": "./build/icons/256x256.png",
      "artifactName": "${productName}-${version}.${ext}",
      "requestedExecutionLevel": "highestAvailable",
      "target": [
        {
          "target": "nsis"
        }
      ]
    },
    "linux": {
      "icon": "./build/icons/256x256.png",
      "artifactName": "${productName}-${version}.${ext}",
      "target": [
        "tar.xz",
        "deb"
      ]
    },
    "protocols": [
      {
        "name": "hiprint",
        "schemes": [
          "hiprint"
        ]
      }
    ],
    "publish": null
  },
  "dependencies": {
    "address": "^1.2.0",
    "bwip-js": "^4.5.1",
    "concurrent-tasks": "^1.0.7",
    "dayjs": "^1.11.10",
    "electron-log": "^5.4.2",
    "electron-store": "^8.1.0",
    "ipp": "^2.0.1",
    "jimp": "^1.6.0",
    "jquery": "^3.6.0",
    "jsbarcode": "^3.11.6",
    "node-machine-id": "^1.1.12",
    "nzh": "^1.0.14",
    "pdf-to-printer": "^5.6.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sqlite3": "^6.0.1",
    "unix-print": "^1.2.0",
    "uuid": "^11.0.3",
    "win32-pdf-printer": "^4.0.1"
  },
  "devDependencies": {
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "fs-extra": "^9.1.0",
    "prettier": "^1.16.4",
    "uglify-js": "^3.14.3"
  }
}
